<cell id="cell-6"><cell_type>markdown</cell_type>## 2 — Load Model</cell id="cell-6">
<cell id="cell-7">sweeper = ResolutionSweeper(
    resolutions      = DEFAULT_RESOLUTIONS,   # [224,280,336,392,448,518]
    conf_thresh      = 5.0,
    store_extrinsics = True,
)
sweeper.load_model()</cell id="cell-7">
<cell id="cell-8"><cell_type>markdown</cell_type>## 3 — Run Sweep</cell id="cell-8">
<cell id="cell-9">results = sweeper.run(
    image_dir     = image_dir,
    max_frames    = N_FRAMES,
    gt_extrinsics = gt_extrinsics,
    align         = True,
    with_scale    = True,
)

df = sweeper.to_dataframe(results)
