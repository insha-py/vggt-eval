    (depth_prog,  out_prog["depth_conf"][FRAME_IDX], "Depth Progressive", "Conf Progressive"),
]
for col, (d, c, dt, ct) in enumerate(pairs):
    axes[0, col].imshow(to_display(d), cmap="plasma")
